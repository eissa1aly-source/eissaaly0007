generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(uuid())
  masterPassword String   @unique
  emails        Email[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Email {
  id          String    @id @default(uuid())
  address     String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  services    Service[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Service {
  id              String    @id @default(uuid())
  name            String
  category        String
  status          String
  link            String?
  emailId         String
  email           Email     @relation(fields: [emailId], references: [id])
  credentials     String?
  configFiles     String?
  deploymentType  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
